// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model producto {
  id            String    @id @default(uuid()) @db.Uuid
  nombre        String
  precio        Float
  stock         Int
  activo        Boolean   @default(false)
  creado_en     DateTime  @default(now())
  modificado_en DateTime  @default(now())
  proveedor_id  String    @unique @db.Uuid
  proveedor     proveedor @relation(fields: [proveedor_id], references: [id])
  compras       compra[]
}

model proveedor {
  id            String    @id @default(uuid()) @db.Uuid
  nombre        String
  telefono      String
  email         String    @unique
  activo        Boolean   @default(false)
  creado_en     DateTime  @default(now())
  modificado_en DateTime  @default(now())
  producto      producto?
  marcas        marca[]
}

model marca {
  id            String      @id @default(uuid()) @db.Uuid
  nombre        String
  laboratorio   String
  pais_origen   String
  activo        Boolean     @default(true)
  creado_en     DateTime    @default(now())
  modificado_en DateTime    @default(now())
  proveedores   proveedor[]
}

model cliente {
  id            String   @id @default(uuid()) @db.Uuid
  nombre        String
  telefono      String   @unique
  email         String   @unique
  activo        Boolean  @default(false)
  creado_en     DateTime @default(now())
  modificado_en DateTime @default(now())
  compras       compra[]
}

model compra {
  id              String   @id @default(uuid()) @db.Uuid
  fecha           DateTime @default(now())
  cantidad        Int      @default(0)
  precio_unitario Float    @default(0.0)
  activo          Boolean  @default(false)
  id_cliente      String   @db.Uuid
  cliente         cliente  @relation(fields: [id_cliente], references: [id])
  id_producto     String   @db.Uuid
  producto        producto @relation(fields: [id_producto], references: [id])
}

model usuario {
  id             String          @id @default(uuid()) @db.Uuid
  nombre         String
  email          String          @unique
  telefono       String
  password       String
  rol            rol             @default(cajero)
  creado_en      DateTime        @default(now())
  tokens_sis     token_sis[]
  detalle_cajero detalle_cajero?
}

enum rol {
  admin
  cajero
}

model token_sis {
  id         String   @id @default(uuid()) @db.Uuid
  usuario_id String   @unique @db.Uuid
  token      String
  creado_en  DateTime @default(now())
  expira_en  DateTime
  estado     Boolean  @default(true)
  usuario    usuario  @relation(fields: [usuario_id], references: [id])
}

model detalle_cajero {
  id            String  @id @default(uuid()) @db.Uuid
  usuario_id    String  @unique @db.Uuid
  turno         String
  caja_asignada String
  usuario       usuario @relation(fields: [usuario_id], references: [id])
}
